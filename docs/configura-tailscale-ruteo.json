	// 1. DECLARACIÓN DE PROPIEDAD DEL TAG (Arriba en el archivo)
	"tagOwners": {
		"tag:serv-iie": ["autogroup:admin"],
	},

	"acls": [
		{
			"action": "accept",
			"src":    ["autogroup:member"],
			"dst":    ["*:*"],
		},
	],

	// Define users and devices that can use Tailscale SSH.
	"ssh": [
		// 1. Regla para HUMANOS: Requiere verificación de identidad (check)
		{
			"action": "check",
			"src":    ["autogroup:member"],
			"dst":    ["tag:serv-iie"],
			"users":  ["root", "octavio", "equihuam", "pita", "martha", "maricruz", "julian"],
		},
		// 2. Regla para SERVIDORES (el "salto SSH"): Permite conexión directa (accept)
		{
			"action": "accept",
			"src":    ["tag:serv-iie"],
			"dst":    ["tag:serv-iie"],
			"users":  ["root"],
		},
	],

	// Define postures that will be applied to all rules without any specific
